# --- Core ---
APP_NAME="Sadot Dogs CRM"
ENVIRONMENT=development
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- Database ---
# Postgres (Docker default). For local-without-postgres use SQLite:
# DATABASE_URL=sqlite:///./sadot.db
DATABASE_URL=postgresql+psycopg2://sadot:sadot@db:5432/sadot

# --- Seed admin user (created on startup if missing) ---
FIRST_ADMIN_EMAIL=admin@sadot.local
FIRST_ADMIN_PASSWORD=admin1234
FIRST_ADMIN_NAME=Admin

# --- CORS ---
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Public site (base URL encoded into QR intake links) ---
PUBLIC_SITE_URL=https://sadot.lavit.io

# --- External integrations (mock in phase 1; leave empty to use mocks) ---
WHATSAPP_API_TOKEN=
PAYMENT_PROVIDER_KEY=
SIGNATURE_PROVIDER_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
MONDAY_API_TOKEN=

# --- Follow-up policy ---
FOLLOWUP_DAYS=5
HOME_SUBSCRIPTION_MONTHLY_PRICE=1000
FACILITY_TOTAL_AMOUNT=7200
